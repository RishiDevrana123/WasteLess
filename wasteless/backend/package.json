{
    "name": "wasteless-backend",
    "version": "1.0.0",
    "description": "WasteLess backend API",
    "main": "src/server.js",
    "type": "module",
    "scripts": {
        "dev": "nodemon src/server.js",
        "start": "node src/server.js",
        "test": "NODE_OPTIONS=--experimental-vm-modules vitest run",
        "test:watch": "NODE_OPTIONS=--experimental-vm-modules vitest",
        "test:coverage": "NODE_OPTIONS=--experimental-vm-modules vitest run --coverage",
        "lint": "eslint src/**/*.js",
        "format": "prettier --write src/**/*.js",
        "seed": "node src/scripts/seed.js"
    },
    "dependencies": {
        "axios": "^1.6.5",
        "bcryptjs": "^2.4.3",
        "bullmq": "^5.1.0",
        "cloudinary": "^1.41.0",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.0.1",
        "helmet": "^7.1.0",
        "ioredis": "^5.3.2",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.3",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "node-cron": "^4.2.1",
        "nodemailer": "^6.9.7",
        "openai": "^4.24.1",
        "razorpay": "^2.9.2",
        "socket.io": "^4.6.0",
        "stripe": "^20.3.1"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^1.1.0",
        "eslint": "^8.56.0",
        "fast-check": "^4.5.3",
        "nodemon": "^3.0.2",
        "prettier": "^3.1.1",
        "supertest": "^6.3.4",
        "vitest": "^1.6.1"
    }
}
